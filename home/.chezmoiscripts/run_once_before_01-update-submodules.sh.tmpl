#!{{ .bash }}
. {{ .chezmoi.sourceDir }}/../scripts/lib/dybatpho/init.sh
dybatpho::register_common_handlers

dybatpho::header "Update submodules"
# modules hash: {{ joinPath .chezmoi.sourceDir "../.gitmodules" | include | sha256sum }}
repo_root="$(dybatpho::git_root "{{ .chezmoi.sourceDir }}/..")"
git -C "${repo_root}" add .gitmodules
git -C "${repo_root}" submodule sync --recursive
git -C "${repo_root}" update-index --assume-unchanged .gitmodules
git -C "${repo_root}" submodule update --init \
  {{-   if or .decryptPersonal (not (empty .decryptEnterprise)) }}
  secrets/data \
  {{-   end }}
  {{- if eq .guiServer "W" "X" }}
  silos/icon \
  {{- end }}
  {{- if eq .browser "F" }}
  home/.chezmoitemplates/firefox/chrome/lepton \
  {{- end }}
  {{- if eq .browser "F" "Z" }}
  {{-   if .decryptPersonal }}
  home/private_dot_config/firefox/profiles/personal \
  {{-   end }}
  {{-   range .browserEnterpriseProfiles }}
  home/private_dot_config/firefox/profiles/enterprise-{{ . }} \
  {{-   end }}
  {{- end }}
  {{- if eq .mailClient "T" "B" }}
  {{-   if .decryptPersonal }}
  home/private_dot_config/thunderbird/profiles/personal \
  {{-   end }}
  {{-   range .mailEnterpriseProfiles }}
  home/private_dot_config/thunderbird/profiles/enterprise-{{ . }} \
  {{-   end }}
  {{- end }}
  {{- if eq .terminalMultiplexer "T" }}
  silos/tmux \
  {{- end }}
  {{- if ne .guiServer "0" }}
  home/Multimedia/Pictures/Wallpaper \
  {{- end }}
  home/private_dot_config/nvim
dybatpho::success "Updated submodules"
