[[profile]]
name = "standalone"

{{- if eq .code "c40c40" }}
  [[profile.output]]
  enable = true
  search = ["m=0x419D", "s=", "v=Samsung Display Corp."]
  mode = "2880x1800@120Hz"
  position = "0,0"
  scale = 1.5
  transform = "normal"
  adaptive_sync = false

  [[profile.output]]
  enable = true
  search = ["n=Wayvnc-1"]
  mode = "1920x1080@60Hz"
  position = "2880,0"
  scale = 1
  transform = "normal"
  adaptive_sync = false

[[profile]]
name = "hdmi"
exec = ["eww open bar --screen 1 --id bar1"]

  [[profile.output]]
  enable = true
  search = ["m=CB242Y E", "s=24220B6C83W01", "v=Acer Technologies"]
  mode = "1920x1080@60Hz"
  position = "1920,0"
  scale = 1.0
  transform = "normal"
  adaptive_sync = false

  [[profile.output]]
  enable = true
  search = ["m=0x419D", "s=", "v=Samsung Display Corp."]
  mode = "2880x1800@120Hz"
  position = "0,0"
  scale = 1.5
  transform = "normal"
  adaptive_sync = false

  [[profile.output]]
  enable = true
  search = ["n=Wayvnc-1"]
  mode = "1920x1080@60Hz"
  position = "4800,0"
  scale = 1
  transform = "normal"
  adaptive_sync = false
{{- end }}
