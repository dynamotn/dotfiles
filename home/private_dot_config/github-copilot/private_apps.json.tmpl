{{- $gitSecret := dict }}
{{- if and (eq .place "home") .decryptPersonal }}
{{-   $gitSecret = printf "../secrets/data/%s/git.yaml.age" "personal" | joinPath .chezmoi.sourceDir | include | decrypt | fromYaml }}
{{- else if and (eq .place "office") (has .company .decryptEnterprise) }}
{{-   $gitSecret = printf "../secrets/data/enterprise-%s/git.yaml.age" .company | joinPath .chezmoi.sourceDir | include | decrypt | fromYaml }}
{{- end }}
{{- if index $gitSecret "copilot" }}
{{- $gitSecret.copilot }}
{{- end }}
