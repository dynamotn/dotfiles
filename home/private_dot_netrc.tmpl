{{- range .decryptEnterprise }}
{{-   $commonSecret := printf "../secrets/data/enterprise-%s/common.yaml.age" . | joinPath $.chezmoi.sourceDir | include | decrypt | fromYaml }}
{{-   $gitSecret := printf "../secrets/data/enterprise-%s/git.yaml.age" . | joinPath $.chezmoi.sourceDir | include | decrypt | fromYaml }}
{{-   $top := $ }}
{{-   $device := printf "%s-%s" $top.place $top.kind }}
{{-   range $gitSecret.servers }}
{{-     if and (regexMatch .regexDevices $device) (regexMatch .negativeRegexDevices $device | not) }}
{{-       $username := $commonSecret.account.username }}
{{-       if index . "username" }}
{{-         $username = .username }}
{{-       end }}
{{-       if index . "token" }}
machine {{ .https | trimPrefix "https://" | trimSuffix "/" }} login {{ $username }} password {{ .token }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}
