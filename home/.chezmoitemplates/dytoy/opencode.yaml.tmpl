name: opencode
method: binary
github:
  repo: anomalyco/opencode
  {{- $os := "" }}
  {{- $extension := ".zip" }}
  {{- if eq .chezmoi.os "linux" "android" }}
  {{-   $os = "linux" }}
  {{-   $extension = ".tar.gz" }}
  {{- else if eq .chezmoi.os "darwin" }}
  {{-   $os = "darwin" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- end }}
  release_asset: opencode-{{ $os }}-{{ $arch }}{{ $extension }}
archive:
  - path: opencode
