name: doggo
is_essential: true
method: binary
github:
  repo: mr-karan/doggo
  {{- $os := .chezmoi.os }}
  {{- if eq .chezmoi.os "android" }}
  {{-   $os = "linux" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- end }}
  release_asset: doggo-{{ $os }}-{{ $arch }}.tar.gz
  sha256: doggo_%1v_checksums.txt
archive:
  - path: doggo
