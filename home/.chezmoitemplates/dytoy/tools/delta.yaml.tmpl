name: delta
is_essential: true
{{- if eq .chezmoi.os "linux" "darwin" }}
method: binary
github:
  repo: dandavison/delta
  {{- $os := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $os = "apple-darwin" }}
  {{- else if eq .chezmoi.os "linux" }}
  {{-   $os = "unknown-linux-gnu" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{- $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{- $arch = "aarch64" }}
  {{- end }}
  release_asset: delta-%v-{{ $arch }}-{{ $os }}.tar.gz
archive:
  - path: delta-%v-{{ $arch }}-{{ $os }}/delta
    strip: 1
{{- else if eq "android" "darwin" }}
method: os
termux:
  packages:
    - name: git-delta
macos:
  packages:
    - name: git-delta
{{- end }}
