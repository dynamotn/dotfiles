alpine:
  packages:
    - name: tar
    - name: gzip
    - name: bzip2
    - name: unzip
    - name: xz
    - name: zstd
termux:
  packages:
    - name: tar
    - name: gzip
    - name: bzip2
    - name: unzip
    - name: liblzma
    - name: zstd
macos:
  packages:
    - name: gnu-tar
    - name: gzip
    - name: bzip2
    - name: unzip
    - name: xz
    - name: zstd
