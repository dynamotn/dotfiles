name: betterleaks
method: binary
github:
  repo: betterleaks/betterleaks
  {{- $os := .chezmoi.os }}
  {{- if eq .chezmoi.os "android" }}
  {{-   $os = "linux" }}
  {{- end }}
  {{- $arch := .chezmoi.arch }}
  {{- if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- else if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x64" }}
  {{- end }}
  release_asset: betterleaks_%1v_{{ $os }}_{{ $arch }}.tar.gz
  sha256: checksums.txt
archive:
  - path: betterleaks
