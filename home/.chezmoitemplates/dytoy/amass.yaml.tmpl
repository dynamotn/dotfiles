name: amass
method: binary
github:
  repo: owasp-amass/amass
  {{- $os := .chezmoi.os }}
  {{- if eq .chezmoi.os "linux" }}
  {{-   $os = "linux" }}
  {{- end }}
  release_asset: amass_{{ $os }}_{{ .chezmoi.arch }}.tar.gz
  sha256: amass_checksums.txt
archive:
  - path: amass_{{ $os }}_{{ .chezmoi.arch }}/amass
    strip: 1
